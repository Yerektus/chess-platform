{
  "name": "@chess-platform/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "node ../../packages/config/next-dev.cjs web",
    "prebuild": "pnpm --filter @chess-platform/types build && pnpm --filter @chess-platform/chess-engine build && pnpm --filter @chess-platform/ui build",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-8080}",
    "lint": "next lint",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@chess-platform/chess-engine": "workspace:*",
    "@chess-platform/types": "workspace:*",
    "@chess-platform/ui": "workspace:*",
    "autoprefixer": "^10.4.20",
    "next": "14.2.35",
    "postcss": "8.5.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.3",
    "stockfish": "^18.0.7",
    "tailwindcss": "3.4.19"
  },
  "devDependencies": {
    "@chess-platform/config": "workspace:*",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint-config-next": "14.2.35",
    "typescript": "^5.7.3"
  }
}
